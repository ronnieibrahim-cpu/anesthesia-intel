# Copy to .env for local work; never commit .env. In GitHub Actions these live as
# repository secrets; in Claude Code cloud sessions, as environment variables
# (docs/07 Part 3). There is deliberately NO ANTHROPIC_API_KEY (CLAUDE.md rule 3).

DATABASE_URL=            # Supabase Postgres connection string (URI form)
NCBI_API_KEY=            # optional; raises PubMed rate limits
UNPAYWALL_EMAIL=         # Unpaywall asks for a contact email (no key needed)
RESEND_API_KEY=          # email sending (used from M3)
FEEDBACK_HMAC_SECRET=    # random ~40 chars; signs feedback links (used from M4)
