{#
  digest.html.j2 — the weekly email, V1's only UI (PRD §6). Filled in Milestone M3
  from templates/digest.sample.html (the design/quality bar — see docs/08 §5).

  Design rules (binding, PRD §6): single column, no images, no hero banners, no
  external resources, dark-mode safe. All CSS is inline below. The screened→surfaced
  ratio in the footer is the product's honesty metric and appears every week.

  Each full-writeup item shows labeled parts (richer than the sample's single .summary
  paragraph): Summary (study + results) / Conclusion (the article's bottom line) / Your
  practice / Anesthesia broadly / Looking ahead — the founder's requirement. Each part
  renders only if its field is present. FYI items in one_line mode keep the sample's compact
  single-line style. Feedback links are M4, not here.
#}
<title>Anesthesia Intelligence — Weekly Digest</title>
<style>
  :root {
    --ground: #fbfcfd;
    --surface: #ffffff;
    --ink: #17212b;
    --muted: #59636d;
    --faint: #8a949d;
    --accent: #0d6a68;
    --accent-soft: #0d6a681a;
    --hairline: #e4e8ec;
    --grade-a: #1f8a5b;
    --grade-b: #2f6fc4;
    --grade-c: #b3791f;
    --grade-d: #6b7480;
    --ft: #0d6a68;
    --serif: "Iowan Old Style", "Palatino Linotype", Palatino, Georgia, "Times New Roman", serif;
    --sans: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
  }
  @media (prefers-color-scheme: dark) {
    :root {
      --ground: #0f1519;
      --surface: #161e24;
      --ink: #e9eef2;
      --muted: #9aa6b0;
      --faint: #6f7b85;
      --accent: #55c8c2;
      --accent-soft: #55c8c21f;
      --hairline: #263038;
      --grade-a: #4fbe86;
      --grade-b: #6ba6e6;
      --grade-c: #d6a24e;
      --grade-d: #9aa6b0;
      --ft: #55c8c2;
    }
  }
  :root[data-theme="light"] {
    --ground: #fbfcfd; --surface: #ffffff; --ink: #17212b; --muted: #59636d;
    --faint: #8a949d; --accent: #0d6a68; --accent-soft: #0d6a681a; --hairline: #e4e8ec;
    --grade-a: #1f8a5b; --grade-b: #2f6fc4; --grade-c: #b3791f; --grade-d: #6b7480; --ft: #0d6a68;
  }
  :root[data-theme="dark"] {
    --ground: #0f1519; --surface: #161e24; --ink: #e9eef2; --muted: #9aa6b0;
    --faint: #6f7b85; --accent: #55c8c2; --accent-soft: #55c8c21f; --hairline: #263038;
    --grade-a: #4fbe86; --grade-b: #6ba6e6; --grade-c: #d6a24e; --grade-d: #9aa6b0; --ft: #55c8c2;
  }

  * { box-sizing: border-box; }
  body {
    margin: 0;
    background: var(--ground);
    color: var(--ink);
    font-family: var(--sans);
    line-height: 1.55;
    -webkit-font-smoothing: antialiased;
  }
  .wrap { max-width: 660px; margin: 0 auto; padding: 32px 22px 64px; }

  /* Masthead */
  .masthead { border-bottom: 2px solid var(--ink); padding-bottom: 16px; }
  .kicker {
    font-size: 11px; letter-spacing: 0.16em; text-transform: uppercase;
    color: var(--accent); font-weight: 700;
  }
  .masthead h1 {
    font-family: var(--serif); font-weight: 600; font-size: 30px; line-height: 1.1;
    margin: 8px 0 6px; letter-spacing: -0.01em; text-wrap: balance;
  }
  .dateline {
    font-size: 13px; color: var(--muted); display: flex; gap: 10px; flex-wrap: wrap;
    font-variant-numeric: tabular-nums;
  }
  .brief {
    font-family: var(--serif); font-size: 17px; line-height: 1.5; color: var(--ink);
    margin: 20px 0 0; padding-left: 14px; border-left: 3px solid var(--accent);
  }
  .brief b { font-weight: 600; }

  /* Tier headers */
  .tier { margin-top: 40px; }
  .tier-head {
    display: flex; align-items: baseline; gap: 10px;
    border-bottom: 1px solid var(--hairline); padding-bottom: 6px; margin-bottom: 4px;
  }
  .tier-head .bar { width: 22px; height: 3px; background: var(--accent); border-radius: 2px; }
  .tier-head h2 {
    font-size: 12px; letter-spacing: 0.13em; text-transform: uppercase; font-weight: 700;
    margin: 0; color: var(--ink);
  }
  .tier-head .count { font-size: 12px; color: var(--faint); font-variant-numeric: tabular-nums; }

  /* Items */
  .item { padding: 20px 0; border-bottom: 1px solid var(--hairline); }
  .item:last-child { border-bottom: none; }
  .item h3 {
    font-family: var(--serif); font-weight: 600; font-size: 18px; line-height: 1.32;
    margin: 0 0 8px; letter-spacing: -0.006em; text-wrap: pretty;
  }
  .item h3 a { color: var(--ink); text-decoration: none; border-bottom: 1px solid var(--accent-soft); }
  .item h3 a:hover { border-bottom-color: var(--accent); }
  .meta {
    display: flex; flex-wrap: wrap; align-items: center; gap: 8px;
    font-size: 12.5px; color: var(--muted); margin-bottom: 10px;
    font-variant-numeric: tabular-nums;
  }
  .meta .journal { font-weight: 600; color: var(--ink); }
  .meta .sep { color: var(--faint); }
  .grade {
    display: inline-flex; align-items: center; gap: 4px;
    font-size: 11px; font-weight: 700; letter-spacing: 0.02em;
    padding: 2px 7px; border-radius: 999px; border: 1px solid currentColor;
    white-space: nowrap;
  }
  .grade small { font-weight: 500; letter-spacing: 0; opacity: 0.85; }
  .g-A { color: var(--grade-a); } .g-B { color: var(--grade-b); }
  .g-C { color: var(--grade-c); } .g-D { color: var(--grade-d); }
  .ft {
    font-size: 12px; font-weight: 600; color: var(--ft); text-decoration: none;
    display: inline-flex; align-items: center; gap: 4px;
  }
  .ft::before { content: "↓"; font-weight: 700; }
  .ft:hover { text-decoration: underline; }

  /* Four-part write-up (Summary / Your practice / Anesthesia broadly / Looking ahead) */
  .parts { margin: 0; }
  .part { font-size: 15px; line-height: 1.56; color: var(--ink); margin: 0 0 8px; }
  .part:last-child { margin-bottom: 0; }
  .part .label {
    font-size: 10.5px; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase;
    color: var(--muted); margin-right: 6px;
  }
  .part.caveat .label, .part.caveat { color: var(--muted); }

  /* FYI compact */
  .fyi-item { padding: 12px 0; border-bottom: 1px solid var(--hairline); }
  .fyi-item:last-child { border-bottom: none; }
  .fyi-item a { color: var(--ink); text-decoration: none; font-weight: 500; }
  .fyi-item a:hover { text-decoration: underline; }
  .fyi-line { font-size: 13.5px; }
  .fyi-tag {
    font-size: 11px; font-weight: 700; padding: 1px 5px; border-radius: 4px;
    border: 1px solid currentColor; margin-right: 7px; vertical-align: 1px;
  }
  .fyi-note { color: var(--muted); font-size: 13px; }

  /* Footer */
  .footer {
    margin-top: 44px; padding-top: 16px; border-top: 2px solid var(--ink);
    font-size: 12.5px; color: var(--muted); line-height: 1.6;
  }
  .footer .metric { color: var(--ink); font-weight: 600; font-variant-numeric: tabular-nums; }
  .footer .build {
    margin-top: 12px; font-size: 11.5px; color: var(--faint);
    background: var(--accent-soft); padding: 10px 12px; border-radius: 8px;
  }
  a:focus-visible { outline: 2px solid var(--accent); outline-offset: 2px; border-radius: 2px; }
</style>

<div class="wrap">
  <header class="masthead">
    <div class="kicker">Anesthesia Intelligence</div>
    <h1>Weekly Digest</h1>
    <div class="dateline">
      <span>{{ digest_date }}</span><span class="sep">·</span>
      <span>{{ window_label }}</span><span class="sep">·</span>
      <span>{{ practice_label }}</span>
    </div>
    {% if week_in_brief %}
    <p class="brief">{{ week_in_brief }}</p>
    {% endif %}
  </header>

  {% for tier in tiers %}
  {% if tier.count > 0 %}
  <section class="tier">
    <div class="tier-head">
      <span class="bar"></span>
      <h2>{{ tier.label }}</h2>
      <span class="count">{{ tier.count }}</span>
    </div>

    {# tier['items'] not tier.items — "items" is also dict.items(), and Jinja's
       attribute lookup tries getattr before __getitem__, so dot access would
       silently resolve to the bound method instead of the tier's article list. #}
    {% for item in tier['items'] %}
    {% if item.full_writeup %}
    <article class="item">
      <h3><a href="{{ item.url }}">{{ item.title }}</a></h3>
      <div class="meta">
        <span class="journal">{{ item.journal }}</span><span class="sep">·</span>
        <span>{{ item.design_line }}</span><span class="sep">·</span>
        <span>{{ item.date }}</span>
        <span class="grade g-{{ item.evidence_level }}">{{ item.evidence_level }} <small>{{ item.grade_label }}</small></span>
        {% if item.oa_url %}
        <a class="ft" href="{{ item.oa_url }}">Free full text</a>
        {% endif %}
      </div>
      <div class="parts">
        {% if item.summary %}
        <p class="part"><span class="label">Summary</span>{{ item.summary }}</p>
        {% endif %}
        {% if item.conclusion %}
        <p class="part"><span class="label">Conclusion</span>{{ item.conclusion }}</p>
        {% endif %}
        {% if item.practice_impact %}
        <p class="part"><span class="label">Your practice</span>{{ item.practice_impact }}</p>
        {% endif %}
        {% if item.field_impact %}
        <p class="part"><span class="label">Anesthesia broadly</span>{{ item.field_impact }}</p>
        {% endif %}
        {% if item.future_considerations %}
        <p class="part caveat"><span class="label">Looking ahead</span>{{ item.future_considerations }}</p>
        {% endif %}
      </div>
    </article>
    {% else %}
    <div class="fyi-item">
      <div class="fyi-line">
        <span class="fyi-tag g-{{ item.evidence_level }}">{{ item.evidence_level }}</span>
        <a href="{{ item.url }}">{{ item.title }}</a>
        <span class="fyi-note">— {{ item.one_line_takeaway }}</span>
        {% if item.oa_url %}
        <a class="ft" href="{{ item.oa_url }}">Free full text</a>
        {% endif %}
      </div>
    </div>
    {% endif %}
    {% endfor %}
  </section>
  {% endif %}
  {% endfor %}

  <footer class="footer">
    <div><span class="metric">{{ screened_count }} items screened · {{ surfaced_count }} surfaced ({{ surfaced_pct }}%)</span>
      Free full-text links found for {{ oa_count }} of {{ surfaced_count }} surfaced items.</div>
    <div>{{ sources_line }}</div>
    {% if build_note %}
    <div class="build">{{ build_note }}</div>
    {% endif %}
  </footer>
</div>
