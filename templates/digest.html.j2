  {# ■ WORTH KNOWING (≤12): same layout, tighter. #}
  {# TODO M3: worth_knowing block #}

  {# ■ FYI (≤15): title + one line each. #}
  {# TODO M3: fyi block #}

  <hr>
  <p style="font-size: small;">
    Pipeline health: {{ health_line }} · {{ screened_count }} items screened ·
